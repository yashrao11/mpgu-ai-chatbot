# Provider mode: auto | gemini | openai | huggingface | knowledge
AI_PROVIDER=auto

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_URL_TEMPLATE=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={api_key}

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_API_URL=https://api.openai.com/v1/responses

# Hugging Face
HUGGING_FACE_TOKEN=
HUGGING_FACE_API_URL=https://api-inference.huggingface.co/models/google/flan-t5-base

# App
REQUEST_TIMEOUT_SECONDS=15
SECRET_KEY=change-this
